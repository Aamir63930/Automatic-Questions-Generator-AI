generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model College {
  id        String         @id @default(uuid())
  name      String
  domain    String         @unique
  logoUrl   String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  classes   ClassSection[]
  materials Material[]
  papers    Paper[]
  tasks     Task[]
  users     User[]
}

model ClassSection {
  id         String     @id @default(uuid())
  collegeId  String
  name       String
  section    String
  semester   Int
  branch     String
  year       Int
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  uniqueCode String     @unique
  college    College    @relation(fields: [collegeId], references: [id])
  materials  Material[]
  tasks      Task[]     @relation("TaskClass")
  students   User[]     @relation("StudentClass")
}

model User {
  id             String         @id @default(uuid())
  collegeId      String
  name           String
  email          String         @unique
  role           Role
  azureOid       String?        @unique
  avatarUrl      String?
  department     String?
  rollNumber     String?
  isActive       Boolean        @default(true)
  lastLogin      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  classSectionId String?
  subjects       String[]       @default([])
  complaints     Complaint[]    @relation("ComplaintRaiser")
  materials      Material[]
  notifications  Notification[]
  submissions    Submission[]
  tasks          Task[]         @relation("TaskCreator")
  classSection   ClassSection?  @relation("StudentClass", fields: [classSectionId], references: [id])
  college        College        @relation(fields: [collegeId], references: [id])
}

model Material {
  id             String         @id @default(uuid())
  collegeId      String
  uploadedBy     String
  title          String
  fileName       String
  fileUrl        String
  fileType       MaterialType
  fileSizeKb     Int?
  status         MaterialStatus @default(ready)
  isPyq          Boolean        @default(false)
  year           Int?
  createdAt      DateTime       @default(now())
  classSectionId String?
  examType       String?
  subject        String?
  unit           String?
  classSection   ClassSection?  @relation(fields: [classSectionId], references: [id])
  college        College        @relation(fields: [collegeId], references: [id])
  uploader       User           @relation(fields: [uploadedBy], references: [id])
}

model Task {
  id               String        @id @default(uuid())
  collegeId        String
  createdBy        String
  title            String
  description      String?
  taskType         TaskType
  deadline         DateTime?
  maxMarks         Int           @default(10)
  instructions     String?
  attachmentUrl    String?
  allowLate        Boolean       @default(false)
  latePenalty      Int           @default(0)
  status           TaskStatus    @default(active)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  classSectionId   String?
  extendedDeadline DateTime?
  subjectName      String?
  submissions      Submission[]
  classSection     ClassSection? @relation("TaskClass", fields: [classSectionId], references: [id])
  college          College       @relation(fields: [collegeId], references: [id])
  creator          User          @relation("TaskCreator", fields: [createdBy], references: [id])
}

model Submission {
  id           String       @id @default(uuid())
  taskId       String
  studentId    String
  fileUrl      String?
  fileName     String?
  textAnswer   String?
  status       SubmitStatus @default(submitted)
  marksAwarded Int?
  feedback     String?
  gradedBy     String?
  gradedAt     DateTime?
  submittedAt  DateTime     @default(now())
  student      User         @relation(fields: [studentId], references: [id])
  task         Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, studentId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String   @default("system")
  refId     String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Complaint {
  id         String             @id @default(uuid())
  raisedBy   String
  subject    String
  category   String?
  status     ComplaintStatus    @default(open)
  priority   String             @default("normal")
  resolvedAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  raiser     User               @relation("ComplaintRaiser", fields: [raisedBy], references: [id])
  messages   ComplaintMessage[]
}

model ComplaintMessage {
  id          String    @id @default(uuid())
  complaintId String
  sentBy      String
  message     String
  createdAt   DateTime  @default(now())
  senderName  String    @default("User")
  senderRole  String    @default("student")
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
}

model Paper {
  id         String   @id @default(uuid())
  collegeId  String
  createdBy  String
  title      String
  subject    String
  examType   String
  totalMarks Int
  duration   Int      @default(180)
  pdfUrl     String?
  status     String   @default("draft")
  questions  Json     @default("[]")
  createdAt  DateTime @default(now())
  college    College  @relation(fields: [collegeId], references: [id])
}

enum Role {
  admin
  hod
  teacher
  student
}

enum MaterialType {
  notes
  pyq
  textbook
  other
}

enum MaterialStatus {
  uploaded
  processing
  ready
  failed
}

enum TaskType {
  assignment
  class_test
  quiz
  project
}

enum TaskStatus {
  active
  closed
  draft
}

enum SubmitStatus {
  submitted
  late
  missing
  graded
}

enum ComplaintStatus {
  open
  in_progress
  resolved
  closed
}
